# ── Server ──────────────────────────────────────────────
PORT=3000

# ── Groq API (LLM Provider) ────────────────────────────
GROQ_API_KEY=api
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenAI (Embeddings for RAG) ────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Embeddings Provider ─────────────────────────────────
# local = free local hashing embeddings (default, no API billing)
# openai = use OpenAI embeddings API (requires OPENAI_API_KEY + billing)
EMBEDDING_PROVIDER=local
EMBEDDING_DIM=384

# ── ChromaDB (Vector Store) ────────────────────────────
# Use a Chroma server URL (recommended with current client setup)
# Example: http://localhost:8000
CHROMA_DB_PATH=http://localhost:8000
