{

  "name": "azure-ai-code-assistant",

  "displayName": "Azure AI Code Assistant",

  "description": "Smart Azure SDK code suggestions for VS Code",

  "publisher": "TEAMEKLAVYA",

  "repository": {

    "type": "git",

    "url": "https://github.com/ArjunDivraniya/Doppelganger-March-2026-Eklavya"

  },

  "logo": "logo.png",

  "private": true,

  "version": "1.0.0",

  "engines": {

    "vscode": "^1.75.0"

  },

  "categories": [

    "Other"

  ],

  "activationEvents": [

    "onLanguage:typescript",

    "onLanguage:javascript",

    "onLanguage:typescriptreact",

    "onLanguage:javascriptreact",

    "onLanguage:csharp"

  ],

  "main": "./out/extension.js",

  "contributes": {

    "configuration": {

      "title": "AzureAI Code Suggest",

      "properties": {

        "azureai.inlineSuggestReminder": {

          "type": "boolean",

          "default": true,

          "description": "Reminder: enable editor.inlineSuggest.enabled in VS Code for ghost text suggestions."

        }

      }

    },

    "commands": [

      {

        "command": "azureai.suggest",

        "title": "AzureAI: Get Suggestion",

        "icon": "$(azure)"

      },

      {

        "command": "azureai.showDebugLogs",

        "title": "AzureAI: Show Debug Logs"

      },

      {

        "command": "azureai.debugProbe",

        "title": "AzureAI: Debug Probe (Run Once)"

      },

      {

        "command": "azureai.acceptSuggestion",

        "title": "AzureAI: Accept Suggestion"

      }

    ],

    "keybindings": [

      {

        "command": "azureai.suggest",

        "key": "ctrl+shift+.",

        "mac": "cmd+shift+.",

        "when": "editorTextFocus"

      }

    ]

  },

  "scripts": {

    "vscode:prepublish": "npm run compile",

    "compile": "tsc -p ./",

    "watch": "tsc -watch -p ./",

    "pretest": "npm run compile && npm run lint",

    "lint": "eslint src --ext ts",

    "test": "node ./out/test/runTest.js"

  },

  "dependencies": {

    "@vscode/vsce": "^3.7.1",

    "axios": "^1.13.6"

  },

  "devDependencies": {

    "@types/node": "^25.3.5",

    "@types/vscode": "^1.75.0",

    "typescript": "^5.0.0"

  }

}

