{
  "name": "azure-ai-code-suggest",
  "displayName": "AzureAI Code Suggest",
  "description": "Smart Azure SDK code suggestions for VS Code",
  "version": "1.0.0",
  "publisher": "ArjunDivraniya",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "azureai.suggest",
        "title": "AzureAI: Get Suggestion",
        "icon": "$(azure)"
      }
    ],
    "keybindings": [
      {
        "command": "azureai.suggest",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}